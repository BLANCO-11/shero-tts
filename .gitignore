# Python Virtual Environment
.venv/
venv/
env/
ENV/
pyvenv.cfg
.python-version

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Project configuration / Local variables
.env
.env*.local
!.env.example

# Next.js build & dev files
.next/
out/
build/
next-env.d.ts
.tsbuildinfo
frontend/.next/
frontend/out/
frontend/build/
frontend/next-env.d.ts
frontend/.tsbuildinfo

# Node dependencies
node_modules/
frontend/node_modules/

# Logs
*.log
backend.log
frontend.log
frontend/build.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Process IDs
*.pid
backend.pid
frontend.pid

# OS files
.DS_Store
Thumbs.db

# Databases (SQLite)
*.db
*.sqlite
*.sqlite3
shero_tts.db
shero_tts.db-journal
shero_tts.db-wal

# Ignore user uploaded custom voices
voices/custom/*
!voices/custom/.gitkeep

# Ignore voice-zero audio weights and files (kept on host and mounted)
voices/voice-zero/*
!voices/voice-zero/.gitkeep
